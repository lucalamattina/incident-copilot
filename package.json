{
  "name": "incident-copilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/fixtures/seed.ts",
    "ingest": "tsx src/rag/ingest.ts",
    "chat": "tsx src/cli/repl.ts",
    "eval:tier1": "tsx src/eval/harness.ts",
    "eval:tier2:verdicts": "tsx src/eval/tierTwo/verdicts.ts",
    "eval:tier2": "tsx src/eval/tierTwo/sampling.ts",
    "eval:tier2:calibrate": "tsx src/eval/tierTwo/calibration.ts",
    "eval:tier3": "tsx src/eval/tierThree/runner.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "dotenv": "^17.4.2",
    "fastembed": "^2.1.0",
    "kysely": "^0.29.2",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
